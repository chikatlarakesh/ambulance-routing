[flake8]
max-line-length = 100
extend-ignore =
    # Line too long — handled by Black
    E501,
    # Whitespace before ':' — conflicts with Black formatting
    E203,
    # Lambda assignment — style preference
    E731,
    # Line break before binary operator — Black compatible
    W503,
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    .pytest_cache,
    build,
    dist,
    *.egg-info
per-file-ignores =
    # Allow unused imports in __init__ files
    __init__.py: F401
